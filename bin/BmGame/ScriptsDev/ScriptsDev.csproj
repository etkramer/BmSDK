<Project Sdk="Microsoft.NET.Sdk">
  <!-- Compiler options -->
  <PropertyGroup>
    <TargetFramework>net10.0-windows7.0</TargetFramework>
    <Configurations>Debug</Configurations>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
  </PropertyGroup>
  <!-- Language features -->
  <PropertyGroup>
    <LangVersion>14</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <!-- Dependencies -->
  <ItemGroup>
    <!-- MoreLINQ -->
    <Reference Include="MoreLINQ">
      <HintPath>.\..\..\Binaries\Win32\sdk\MoreLinq.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- BmSDK -->
    <Reference Include="BmSDK">
      <HintPath>.\..\..\Binaries\Win32\sdk\BmSDK.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- Tomlyn -->
    <Reference Include="Tomlyn">
      <HintPath>.\..\..\Binaries\Win32\sdk\Tomlyn.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- Hexa.NET.ImGui -->
    <Reference Include="Hexa.NET.ImGui">
      <HintPath>.\..\..\Binaries\Win32\sdk\Hexa.NET.ImGui.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- System.Reactive -->
    <Reference Include="System.Reactive">
      <HintPath>.\..\..\Binaries\Win32\sdk\System.Reactive.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
  <!-- Global imports-->
  <ItemGroup>
    <Using Include="BmSDK.Framework" />
    <Using Include="Tomlyn.Model" />
    <Using Include="Hexa.NET.ImGui" />
    <Using Include="System.Reactive.Linq" />
  </ItemGroup>
  <!-- Importing scripts -->
  <ItemGroup>
    <Compile Include=".\..\Scripts\**\*.cs" />
    <Compile Include=".\..\Mods\**\*.cs" />
  </ItemGroup>
</Project>
